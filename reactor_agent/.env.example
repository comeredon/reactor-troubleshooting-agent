# LLM Provider (groq | openai | anthropic | ollama)
LLM_PROVIDER=groq

# API Keys — set only the one matching your provider
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model for your provider
# LLM_MODEL=llama-3.1-70b-versatile

# Embedding provider (huggingface | openai)
# huggingface is the default (local, no API key required)
EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=all-MiniLM-L6-v2
